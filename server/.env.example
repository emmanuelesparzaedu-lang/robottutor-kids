# Obtén tu API key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=tu_api_key_aqui

# Puerto del servidor backend
PORT=3001

# Modelo de Gemini (opcional)
GEMINI_MODEL=gemini-2.0-flash

# Endurecimiento para uso escolar (opcional)
# Máximo de preguntas por alumno/IP por minuto
RATE_LIMIT_PER_MIN=25
# TTL de cache en milisegundos
CHAT_CACHE_TTL_MS=180000
# Máximo de respuestas guardadas en cache
CHAT_CACHE_MAX_ITEMS=500
# Concurrencia máxima de llamadas simultáneas a Gemini (escuela: 12)
MAX_CONCURRENT_GEMINI=12
# Tiempo máximo de espera en cola (ms)
MAX_QUEUE_WAIT_MS=35000
# Reintentos ante 429/5xx de Gemini
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_MS=900
GEMINI_TIMEOUT_MS=22000
